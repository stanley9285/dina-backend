# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ─── Frontend ─────────────────────────────────────────────────────────────────
# URL of your frontend (Figma Make / Vercel / etc.)
FRONTEND_URL=https://your-frontend-domain.com

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave empty for local dev (defaults to ./dina.db)
# On Render: set to /data/dina.db after adding a persistent disk
DB_PATH=/data/dina.db

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Use a Gmail App Password (not your regular Gmail password)
# Enable it at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=dina@yourdomain.com
ADMIN_PASSWORD=choose-a-strong-password-here

# Generate JWT_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-random-hex-string

# ─── Anthropic / Claude AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
